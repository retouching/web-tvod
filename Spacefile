# Spacefile Docs: https://go.deta.dev/docs/spacefile/v0
v: 0
micros:
  - name: tvod-web
    engine: python3.9
    src: .
    run: flask run --port $PORT
    dev: flask run --port $PORT --debug
    presets:
      env:
        - name: FLASK_APP
          description: Flask app file
          default: "web/app.py"
        - name: PROXY
          description: Proxy to use for doing requests to twitch
